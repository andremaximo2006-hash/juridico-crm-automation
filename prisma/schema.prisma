// ─── MODELS ──────────────────────────────────────────────────────────────────

model Lead {
  id              String         @id @default(cuid())
  name            String
  cpf             String?        @unique
  email           String?
  phone           String
  profession      String?
  estimatedIncome Decimal?       @db.Decimal(10, 2)
  originChannel   OriginChannel?
  legalArea       LegalArea?
  caseSummary     String?
  funnelStage     FunnelStage    @default(new_lead)
  lostReason      String?
  referralById    String?
  createdAt       DateTime       @default(now())
  stageUpdatedAt  DateTime       @default(now())

  referralBy      Client?        @relation("ReferredBy", fields: [referralById], references: [id])
  client          Client?        @relation("LeadToClient")
  timeline        LeadTimeline[]
  campaigns       LeadCampaign[]

  // WhatsApp IA Relations
  whatsappConversations  WhatsAppConversation[]
  whatsappTickets        WhatsAppHumanTicket[]

  @@map("leads")
}

model LeadTimeline {
  id           String            @id @default(cuid())
  leadId       String
  eventType    TimelineEventType
  description  String?
  nextAction   String?
  nextActionAt DateTime?
  createdAt    DateTime          @default(now())

  lead         Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_timeline")
}

model Client {
  id             String   @id @default(cuid())
  leadId         String?  @unique
  name           String
  cpf            String   @unique
  email          String?
  phone          String
  profession     String?
  address        Json?
  astreaClientId String?
  whatsappOptIn  Boolean  @default(true)
  createdAt      DateTime @default(now())

  lead           Lead?          @relation("LeadToClient", fields: [leadId], references: [id])
  referrals      Lead[]         @relation("ReferredBy")
  cases          Case[]
  transactions   Transaction[]
  notifications  Notification[]
  aiChats        AIChat[]

  @@map("clients")
}

model Case {
  id               String     @id @default(cuid())
  clientId         String
  leadId           String?
  title            String
  legalArea        LegalArea?
  description      String?
  astreaCaseId     String?
  contractUrl      String?
  contractSignedAt DateTime?
  status           CaseStatus @default(active)
  createdAt        DateTime   @default(now())

  client           Client                    @relation(fields: [clientId], references: [id])
  feeAgreements    FeeAgreement[]
  transactions     Transaction[]
  checklist        AstreaMigrationChecklist?

  @@map("cases")
}

model FeeAgreement {
  id                String   @id @default(cuid())
  caseId            String
  type              FeeType
  amount            Decimal? @db.Decimal(10, 2)
  percentageValue   Decimal? @db.Decimal(5, 2)
  totalInstallments Int      @default(1)
  firstDueDate      DateTime
  recurrenceDay     Int?
  description       String?
  createdAt         DateTime @default(now())

  case              Case          @relation(fields: [caseId], references: [id])
  transactions      Transaction[]

  @@map("fee_agreements")
}

model Transaction {
  id                String              @id @default(cuid())
  feeAgreementId    String?
  caseId            String?
  clientId          String?
  type              TransactionType
  category          TransactionCategory
  description       String?
  amount            Decimal             @db.Decimal(10, 2)
  dueDate           DateTime
  paidDate          DateTime?
  status            TransactionStatus   @default(pending)
  installmentNumber Int?
  totalInstallments Int?
  paymentMethod     PaymentMethod?
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  feeAgreement      FeeAgreement?  @relation(fields: [feeAgreementId], references: [id])
  case              Case?          @relation(fields: [caseId], references: [id])
  client            Client?        @relation(fields: [clientId], references: [id])
  notifications     Notification[]

  @@map("transactions")
}

model OfficeExpense {
  id        String   @id @default(cuid())
  name      String
  category  String?
  amount    Decimal  @db.Decimal(10, 2)
  dueDay    Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("office_expenses")
}

model Notification {
  id            String              @id @default(cuid())
  type          NotificationType
  transactionId String?
  clientId      String?
  leadId        String?
  message       String
  channel       NotificationChannel
  scheduledAt   DateTime
  sentAt        DateTime?
  status        NotificationStatus  @default(pending)
  createdAt     DateTime            @default(now())

  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  client        Client?      @relation(fields: [clientId], references: [id])

  @@map("notifications")
}

model MarketingSpend {
  id          String           @id @default(cuid())
  channel     MarketingChannel
  campaign    String?
  amount      Decimal          @db.Decimal(10, 2)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime         @default(now())

  campaigns   LeadCampaign[]

  @@map("marketing_spends")
}

model LeadCampaign {
  id           String   @id @default(cuid())
  leadId       String
  campaignId   String
  attributedAt DateTime @default(now())

  lead         Lead           @relation(fields: [leadId], references: [id])
  campaign     MarketingSpend @relation(fields: [campaignId], references: [id])

  @@unique([leadId, campaignId])
  @@map("lead_campaigns")
}

model AstreaMigrationChecklist {
  id          String    @id @default(cuid())
  caseId      String    @unique
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  case        Case                  @relation(fields: [caseId], references: [id])
  items       AstreaMigrationItem[]

  @@map("astrea_checklists")
}

model AstreaMigrationItem {
  id          String    @id @default(cuid())
  checklistId String
  label       String
  isDone      Boolean   @default(false)
  doneAt      DateTime?
  sortOrder   Int

  checklist   AstreaMigrationChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@map("astrea_checklist_items")
}

model DashboardWidget {
  id        String   @id @default(cuid())
  widgetKey String   @unique
  label     String
  isVisible Boolean  @default(true)
  sortOrder Int
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@map("dashboard_widgets")
}

model MarketingAnalysis {
  id           String   @id @default(cuid())
  channel      String
  campaign     String?
  periodStart  DateTime
  periodEnd    DateTime
  investimento Decimal  @db.Decimal(10, 2)
  leads        Int
  consultas    Int
  contratos    Int
  receita      Decimal  @db.Decimal(10, 2)
  analysis     String   @db.Text
  createdAt    DateTime @default(now())

  @@map("marketing_analyses")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(padrao)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // WhatsApp IA Relations
  createdRoutines             WhatsAppRoutine[] @relation("RoutinesCreatedBy")
  transferredConversations    WhatsAppConversation[] @relation("ConversationsTransferredTo")
  assignedTickets             WhatsAppHumanTicket[] @relation("HumanTicketsAssignedTo")

  // AI Atendimento Relations
  aiConfiguration             AIConfiguration?
  aiChats                     AIChat[]
  aiAnalytics                 AIAnalytics[]

  // IA Factory Relations
  ias                         IAInstance[] @relation("UserIAs")

  @@map("users")
}

// ⚠️ NOTA: Modelos antigos removidos - use FechamentosEntry, IniciaisEntry, PrazosEntry, etc
// para manter compatibilidade com a estrutura de abas da planilha Excel

// ─── CONFIGURADOR OPERACIONAL (VISUAL CUSTOMIZATION) ────────────────────────

model ConfiguradorOperacional {
  id                String    @id @default(cuid())
  usuarioId         String?   // NULL = global; "user-id" = por usuário
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Cores das Áreas
  corPrevidenciario String    @default("#3B82F6") // blue
  corTrabalhista    String    @default("#10B981") // green
  corCivil          String    @default("#F59E0B") // amber
  corFamilia        String    @default("#EC4899") // pink
  corTributario     String    @default("#8B5CF6") // purple

  // Cores das Colunas Kanban
  corNovoColuna     String    @default("#6B7280") // gray
  corTriagemColuna  String    @default("#3B82F6") // blue
  corAndamentoColuna String   @default("#F59E0B") // amber
  corConcluidoColuna String   @default("#10B981") // green

  // Labels das Colunas (customizáveis)
  labelNovo         String    @default("Novo")
  labelTriagem      String    @default("Triagem")
  labelAndamento    String    @default("Andamento")
  labelConcluido    String    @default("Concluído")

  // Cores de Prioridade
  corBaixa          String    @default("#10B981") // green
  corNormal         String    @default("#3B82F6") // blue
  corAlta           String    @default("#F59E0B") // amber
  corUrgente        String    @default("#EF4444") // red

  // Layout & Tema
  tema              String    @default("light")   // light | dark | auto
  tamanhoCard       String    @default("medium")  // small | medium | large
  mostrarAvatar     Boolean   @default(true)
  mostrarProcesso   Boolean   @default(true)
  mostrarDPP        Boolean   @default(true)
  mostrarAlertas    Boolean   @default(true)
  mostrarObservacoes Boolean  @default(true)

  // Colunas Visíveis
  colunaNovoVisivel       Boolean   @default(true)
  colunaTriagemVisivel    Boolean   @default(true)
  colunaAndamentoVisivel  Boolean   @default(true)
  colunaConcluidoVisivel  Boolean   @default(true)

  // Filtros Padrão
  filtroAreaPadrao  String?   // Área padrão ao abrir
  filtroNaturezaPadrao String? // LEAD | ORGÂNICO
  filtroResponsavelPadrao String? // Responsável padrão

  // Limites & Paginação
  registrosPorPagina Int      @default(50)
  autoRefreshStats   Int      @default(30)    // segundos
  mostrarStatsPorColuna Boolean @default(true)

  // Validações & Regras
  requererMotivoMovimento Boolean @default(false)
  bloqueioAutomatico      Boolean @default(true)
  notificacoes            Boolean @default(true)

  // Relações
  historicos PresetConfigurador[]
  histAuditar HistoricoConfigurador[]

  @@unique([usuarioId]) // Um config por usuário
  @@map("configurador_operacional")
}

// ─── PRESET CONFIGURADOR (SAVED TEMPLATES) ─────────────────────────────────

model PresetConfigurador {
  id                String    @id @default(cuid())
  nome              String    // "Tema Escuro", "Tema Colorido", etc
  descricao         String?
  isPublico         Boolean   @default(true) // Compartilhado com todos
  criadoPor         String    // email/id do usuário
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Configuração (JSON serializado)
  configuracao      Json      // ConfiguradorOperacional sem id/usuarioId

  // Relação
  configuradorId    String?
  configurador      ConfiguradorOperacional? @relation(fields: [configuradorId], references: [id], onDelete: SetNull)

  // Auditoria
  usosCount         Int       @default(0) // Quantas vezes foi aplicado
  ultimoUsoEm       DateTime?

  @@map("preset_configurador")
}

// ─── HISTÓRICO CONFIGURADOR (AUDIT LOG) ────────────────────────────────────

model HistoricoConfigurador {
  id                String    @id @default(cuid())
  configuradorId    String
  configurador      ConfiguradorOperacional @relation(fields: [configuradorId], references: [id], onDelete: Cascade)

  usuarioId         String    // Quem fez a mudança
  acao              String    // "alterou_cores", "renomeou_coluna", "aplicou_preset", "exportou", etc

  // O que mudou
  campoAlterado     String?   // Nome do campo (ex: "corPrevidenciario")
  valorAnterior     String?   // Valor antes
  valorNovo         String?   // Valor depois

  // Contexto
  descricao         String?   // Descrição legível da mudança
  ipAddress         String?
  userAgent         String?

  createdAt         DateTime  @default(now())

  @@map("historico_configurador")
}

// ─── TECLA PERSONALIZADA (KEYBOARD SHORTCUTS) ──────────────────────────────

model TeclaPersonalizada {
  id                String    @id @default(cuid())
  usuarioId         String    // Por usuário

  acao              String    // "salvar_config", "exportar", "importar", "abrir_filtros", etc
  teclaCombo        String    // "Ctrl+S", "Cmd+E", "Alt+Shift+X", etc
  descricao         String?   // Descrição legível
  ativo             Boolean   @default(true)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([usuarioId, acao])
  @@map("tecla_personalizada")
}

// ─── END CONFIGURADOR MODELS ───────────────────────────────────────────────

// ─── FICHA OPERACIONAL (NEW KANBAN MODEL) ─────────────────────────────────

model FichaOperacional {
  id                String              @id @default(cuid())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Cliente
  nome              String              // required
  contato           String?             // WhatsApp format: "13 99999-9999"
  natureza          NaturezaFicha       // LEAD | ORGANICO

  // Processo
  area              AreaAtuacao         // required
  beneficio         String              // required — lookup from BENEFICIOS[area]
  tipoRequerimento  TipoRequerimento?
  numeroProcesso    String?             // e.g., "5003633-17.2025.4.03.6311"
  dataEntrada       DateTime
  dataProtocolo     DateTime?
  numeroProtocolo   String?

  // Responsável
  responsavel       Responsavel         // required — team member
  setor             String?             // "Recepção" | "Iniciais" | "Relacionamento"
  coluna            KanbanColuna        @default(novo)
  prioridade        Prioridade          @default(normal)

  // Documentação
  cadSenha          StatusCadSenha?
  conformidade      StatusConformidade?

  // Salário Maternidade (optional)
  smContribuicao    ContribuicaoSM?
  smDpp             DateTime?           // Data Prevista do Parto
  smQuemPaga        QuemPagaSM?
  smStatusGuia      StatusGuia?

  // Text
  observacoes       String?             @db.Text
  historicoLog      String?             @db.Text  // append-only, ISO date + user + action

  @@map("fichas_operacionais")
}

// ─── IMPORTAÇÃO POR ABAS DA PLANILHA ──────────────────────────────────────

model FechamentosEntry {
  id           String   @id @default(cuid())
  data         DateTime?
  cliente      String   // required
  contato      String?
  natureza     String?
  area         String?
  beneficio    String?
  observacao   String?  @db.Text
  setor        String?
  cadSenha     String?
  statusAtual  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("fechamentos_entries")
  @@index([cliente])
  @@index([area])
}

model IniciaisEntry {
  id                String   @id @default(cuid())
  cliente           String   // required
  processo          String?
  area              String?
  tipoRequerimento  String?
  dataInicial       DateTime?
  protocolo         String?
  responsavel       String?
  status            String?
  observacoes       String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("iniciais_entries")
  @@index([cliente])
  @@index([area])
}

model PrazosEntry {
  id                String   @id @default(cuid())
  cliente           String   // required
  processo          String?
  area              String?
  tipoPrazo         String?
  dataInicial       DateTime?
  dataFinal         DateTime?
  responsavel       String?
  status            String?
  observacoes       String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("prazos_entries")
  @@index([cliente])
  @@index([dataFinal])
}

model SalMaternidadeEntry {
  id           String   @id @default(cuid())
  cliente      String   // required
  contato      String?
  beneficio    String?
  contribuicao String?
  dppOuDn      DateTime?
  pagamento    String?
  planejamento String?
  status       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sal_maternidade_entries")
  @@index([cliente])
  @@index([dppOuDn])
}

model CadSenhaEntry {
  id                String   @id @default(cuid())
  entrada           DateTime?
  cliente           String   // required
  contato           String?
  natureza          String?
  beneficio         String?
  procuracao        String?
  substabelecimento String?
  rg                String?
  status            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("cad_senha_entries")
  @@index([cliente])
}

model ConcessoesEntry {
  id                String   @id @default(cuid())
  data              DateTime // required
  cliente           String   // required
  beneficio         String?
  dataRecebimento   DateTime?
  valorHonorarios   Decimal? @db.Decimal(10, 2)
  boletos           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("concessoes_entries")
  @@index([cliente])
  @@index([data])
}

model RelatoriosEntry {
  id           String   @id @default(cuid())
  mes          Int?
  ano          Int?
  tipo         String?
  descricao    String?  @db.Text
  valor        Int?
  observacoes  String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("relatorios_entries")
  @@index([ano, mes])
}

model AcessosEntry {
  id       String   @id @default(cuid())
  sistema  String   // required
  login    String?
  senha    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("acessos_entries")
  @@index([sistema])
}

model Pagina16Entry {
  id                String   @id @default(cuid())
  numero            Int?
  cliente           String   // required
  demanda           String?
  area              String?
  tipoRequerimento  String?
  data              DateTime?
  responsavel       String?
  observacao        String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("pagina16_entries")
  @@index([cliente])
  @@index([area])
}

model AppSetting {
  key   String @id
  value String

  @@map("app_settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userName   String?
  action     String   // CREATE | UPDATE | DELETE
  entity     String   // leads | clientes | financeiro | operacional
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// ─── PREVISIBILIDADE (REVENUE FORECASTING) ────────────────────────────────

enum PrevisibilidadeAreaJuridica {
  previdenciario
  trabalhista
  familia
  civil
  outro
}

enum PrevisibilidadeOrigemLead {
  metaAds
  googleAds
  tiktokAds
  linkedinAds
  organico
  outro
}

enum PrevisibilidadeSituacao {
  beneficioConcedido
  beneficioNegado
  emAndamento
  semViabilidade
}

model PrevisibilidadeProduto {
  id                    String   @id @default(cuid())
  nome                  String   @unique
  honorarioMedio        Decimal  @db.Decimal(10, 2)
  probRecebimento       Decimal  @db.Decimal(5, 2)
  custoOperac           Decimal  @db.Decimal(5, 2)
  metaFatMensal         Decimal  @db.Decimal(12, 2)
  convLeadAtend         Decimal  @db.Decimal(5, 2)
  convAtendContrato     Decimal  @db.Decimal(5, 2)
  cplRef                Decimal  @db.Decimal(10, 2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  fechamentos           PrevisibilidadeFechamento[]

  @@map("previsibilidade_produtos")
}

model PrevisibilidadeCanalPago {
  id                String   @id @default(cuid())
  canal             String   @unique
  metaOrcamento     Decimal  @db.Decimal(12, 2)
  cpcMedio          Decimal  @db.Decimal(10, 2)
  convCliqueLead    Decimal  @db.Decimal(5, 2)
  cplMeta           Decimal  @db.Decimal(10, 2)
  retornoPercent    Decimal  @db.Decimal(5, 2)
  obs               String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("previsibilidade_canais_pago")
}

model PrevisibilidadeFechamento {
  id              String                            @id @default(cuid())
  data            DateTime
  cliente         String
  produtoId       String
  area            PrevisibilidadeAreaJuridica
  canal           PrevisibilidadeOrigemLead
  setor           String?
  obs             String?
  situacao        PrevisibilidadeSituacao
  honorarios      Decimal?                          @db.Decimal(12, 2)
  createdAt       DateTime                          @default(now())
  updatedAt       DateTime                          @updatedAt

  produto         PrevisibilidadeProduto            @relation(fields: [produtoId], references: [id], onDelete: Restrict)

  @@map("previsibilidade_fechamentos")
}

// ─── WHATSAPP IA INTEGRATION ───────────────────────────────────────────────

// Roteiros configuráveis (system prompts por área jurídica)
model WhatsAppRoutine {
  id              String    @id @default(cuid())
  legalArea       String    @unique @map("legal_area")
  name            String?
  systemPrompt    String    @map("system_prompt")  // System prompt da IA
  tools           Json?
  active          Boolean   @default(true)
  version         Int       @default(1)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdBy       User?     @relation("RoutinesCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById     String?   @map("created_by_id")

  @@index([legalArea])
  @@index([active])
  @@map("whatsapp_routines")
}

// Conversas WhatsApp
model WhatsAppConversation {
  id                        String   @id @default(cuid())
  leadId                    String   @map("lead_id")
  lead                      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  platform                  WhatsAppPlatform?
  platformContactId         String?  @map("platform_contact_id")
  phoneNumber               String?  @map("phone_number")
  legalArea                 String?  @map("legal_area")
  conversationHistory       Json?    @map("conversation_history")  // [{"role": "user/assistant", "content": "..."}]
  status                    WhatsAppConversationStatus @default(active)
  transferredToHumanAt      DateTime? @map("transferred_to_human_at")
  transferredToAttendant    User?    @relation("ConversationsTransferredTo", fields: [transferredToAttendantId], references: [id], onDelete: SetNull)
  transferredToAttendantId  String?  @map("transferred_to_attendant_id")
  attendantNotes            String?  @map("attendant_notes")
  metadata                  Json?
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  // Relações
  humanTickets              WhatsAppHumanTicket[]
  qualificacao              WhatsAppQualificacao?
  tarefas                   WhatsAppTarefa[]
  roteiro                   WhatsAppRoteiro?     @relation("ConversationRoteiro", fields: [roteiroId], references: [id], onDelete: SetNull)
  roteiroId                 String?              @map("roteiro_id")

  @@index([leadId])
  @@index([status])
  @@index([transferredToAttendantId])
  @@index([roteiroId])
  @@map("whatsapp_conversations")
}

// Fila de atendimento humano
model WhatsAppHumanTicket {
  id                        String   @id @default(cuid())
  conversationId            String   @map("conversation_id")
  conversation              WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  leadId                    String   @map("lead_id")
  lead                      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  reason                    String?
  priority                  WhatsAppHumanTicketPriority @default(normal)
  status                    WhatsAppHumanTicketStatus @default(pending)
  assignedToAttendant       User?    @relation("HumanTicketsAssignedTo", fields: [assignedToAttendantId], references: [id], onDelete: SetNull)
  assignedToAttendantId     String?  @map("assigned_to_attendant_id")
  assignedAt                DateTime? @map("assigned_at")
  resolvedAt                DateTime? @map("resolved_at")
  resolutionNotes           String?  @map("resolution_notes")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([assignedToAttendantId])
  @@index([priority])
  @@map("whatsapp_human_tickets")
}

// ─── WHATSAPP IA SDR MODELS ───────────────────────────────────────────────

// Roteiro de atendimento (configurável)
model WhatsAppRoteiro {
  id            String   @id @default(cuid())
  name          String   // "Roteiro Previdenciário"
  description   String?
  isActive      Boolean  @default(true) @map("is_active")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  steps         WhatsAppRoteiroStep[] @relation("RoteiroSteps")
  conversations WhatsAppConversation[] @relation("ConversationRoteiro")

  @@map("whatsapp_roteiros")
}

// Passo do roteiro (pergunta)
model WhatsAppRoteiroStep {
  id            String   @id @default(cuid())
  roteiroId     String   @map("roteiro_id")
  roteiro       WhatsAppRoteiro @relation("RoteiroSteps", fields: [roteiroId], references: [id], onDelete: Cascade)

  // Ordem
  order         Int      // 1, 2, 3...

  // Pergunta
  pergunta      String   // "Qual é a sua área jurídica?"
  tipo          String   @default("text") // "text", "multiple_choice", "date", "phone"
  isRequired    Boolean  @default(true) @map("is_required")

  // Respostas possíveis (para multiple_choice)
  respostas     Json?    // [{ label: "Família", value: "familia" }]

  // Próximo passo
  proximoStep   Int?     @map("proximo_step")
  condicoes     Json?    // Lógica de branching

  // Validação
  regex         String?  // Para validar formato

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([roteiroId, order])
  @@map("whatsapp_roteiro_steps")
}

// Qualificação do lead (scoring)
model WhatsAppQualificacao {
  id            String   @id @default(cuid())
  conversationId String   @unique @map("conversation_id")
  conversation  WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Dados coletados
  dados         Json     @default("{}") // { "area": "familia", "situacao": "divorcio" }

  // Scoring
  score         Int      @default(0)    // 0-100
  viabilidade   String   @default("pendente") // "viavel", "inviavel"
  motivo        String?  // Por que é inviável?

  // Encaminhamento
  encaminhadoEm DateTime? @map("encaminhado_em")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("whatsapp_qualificacoes")
}

// Tarefa automática do SDR
model WhatsAppTarefa {
  id            String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  conversation  WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Tipo de tarefa
  tipo          String   // "enviar_documento", "agendar_reuniao"
  descricao     String

  // Status
  status        String   @default("pendente") // "pendente", "completo", "erro"
  resultado     Json?

  createdAt     DateTime @default(now()) @map("created_at")
  completadoEm  DateTime? @map("completado_em")

  @@map("whatsapp_tarefas")
}

// Configurações de integrações WhatsApp
model WhatsAppIntegration {
  id                String   @id @default(cuid())
  platform          WhatsAppPlatform
  name              String?
  active            Boolean  @default(true)
  apiKey            String?  @map("api_key")
  apiSecret         String?  @map("api_secret")
  instanceId        String?  @map("instance_id")
  phoneNumberId     String?  @map("phone_number_id")
  channelId         String?  @map("channel_id")
  webhookUrl        String?  @map("webhook_url")
  webhookSecret     String?  @map("webhook_secret")
  settings          Json?
  lastSyncAt        DateTime? @map("last_sync_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([platform, active])
  @@map("whatsapp_integrations")
}

// ─── IA ATENDIMENTO MODELS ───────────────────────────────────────────────────

enum IAType {
  super_agent
  whatsapp_ia
  marketing_ia
}

enum AIChatStatus {
  active
  archived
  escalated
}

enum AIModel {
  haiku
  sonnet
  opus
}

model AIConfiguration {
  id                          String   @id @default(cuid())
  userId                      String   @unique @map("user_id")
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // API Keys (encriptados)
  anthropic_api_key_encrypted String?  @map("anthropic_api_key_encrypted")
  serper_api_key_encrypted    String?  @map("serper_api_key_encrypted")
  lastKeyUpdate               DateTime? @map("last_key_update")

  // Modelo padrão
  defaultModel                AIModel  @default(sonnet) @map("default_model")
  maxTokens                   Int      @default(4096) @map("max_tokens")
  temperature                 Decimal  @default(0.7) @db.Decimal(2, 1)

  // Super Agent Jurídico
  superAgentEnabled           Boolean  @default(true) @map("super_agent_enabled")
  superAgentAutoSearch        Boolean  @default(true) @map("super_agent_auto_search")
  superAgentAutoAlerts        Boolean  @default(true) @map("super_agent_auto_alerts")

  // WhatsApp IA
  whatsappIaEnabled           Boolean  @default(true) @map("whatsapp_ia_enabled")
  whatsappIaAutoRespond       Boolean  @default(true) @map("whatsapp_ia_auto_respond")
  whatsappIaApprovalRequired  Boolean  @default(false) @map("whatsapp_ia_approval_required")
  whatsappIaEscalateDelaySeconds Int   @default(30) @map("whatsapp_ia_escalate_delay_seconds")

  // Marketing IA
  marketingIaEnabled          Boolean  @default(true) @map("marketing_ia_enabled")
  marketingIaAnalysisModels   String[] @default(["roi", "funnel", "cac", "roas"]) @map("marketing_ia_analysis_models")

  // Privacidade
  logConversations            Boolean  @default(true) @map("log_conversations")
  anonymizeSensitiveData      Boolean  @default(true) @map("anonymize_sensitive_data")
  encryptAtRest               Boolean  @default(true) @map("encrypt_at_rest")
  dataRetentionDays           Int      @default(90) @map("data_retention_days")

  // Monitoramento
  maxCallsPerHour             Int      @default(100) @map("max_calls_per_hour")
  maxTokensPerDay             Int      @default(1000000) @map("max_tokens_per_day")
  rateLimitAlert              Boolean  @default(true) @map("rate_limit_alert")
  errorAlertSlack             Boolean  @default(false) @map("error_alert_slack")
  autoRetryEnabled            Boolean  @default(true) @map("auto_retry_enabled")
  autoRetryMaxAttempts        Int      @default(3) @map("auto_retry_max_attempts")

  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("ai_configuration")
}

model AIChat {
  id                String       @id @default(cuid())
  userId            String       @map("user_id")
  iaType            IAType       @map("ia_type")

  // Conversação
  messages          Json         @default("[]")
  sessionId         String?      @unique @map("session_id")

  // Metadados
  totalTokens       Int          @default(0) @map("total_tokens")
  totalCost         Decimal      @default(0) @db.Decimal(10, 4) @map("total_cost")
  status            AIChatStatus @default(active)

  // Timestamps
  startedAt         DateTime     @default(now()) @map("started_at")
  endedAt           DateTime?    @map("ended_at")
  lastMessageAt     DateTime     @default(now()) @map("last_message_at")

  // Cliente associado (opcional)
  clientId          String?      @map("client_id")
  client            Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Tags e categorização
  tags              String[]     @default([])
  notes             String?

  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([iaType])
  @@index([clientId])
  @@index([createdAt(sort: Desc)])
  @@map("ai_chat")
}

model AIAnalytics {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")

  // Data (agregada por dia)
  date              DateTime @map("date")
  iaType            IAType   @map("ia_type")

  // Métricas
  totalConversations Int     @default(0) @map("total_conversations")
  totalMessages     Int      @default(0) @map("total_messages")
  totalTokensUsed   Int      @default(0) @map("total_tokens_used")
  totalCost         Decimal  @default(0) @db.Decimal(10, 4) @map("total_cost")

  avgResponseTimeMs Int      @default(0) @map("avg_response_time_ms")
  avgSatisfactionScore Decimal @default(0) @db.Decimal(3, 1) @map("avg_satisfaction_score")

  errorsCount       Int      @default(0) @map("errors_count")
  retriesCount      Int      @default(0) @map("retries_count")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, iaType])
  @@index([date(sort: Desc)])
  @@map("ai_analytics")
}

// ─── IA FACTORY MODELS ───────────────────────────────────────────────────

enum IACanal {
  whatsapp
  email
  webchat
  telefone
  instagram
  linkedin
  custom
}

enum IATemplateTipo {
  sdr_qualificacao
  suporte_tecnico
  email_responder
  chatbot_visitante
  consultor_legal
  prospeccao
  custom
}

// Template de IA (reutilizável)
model IATemplateModel {
  id                String        @id @default(cuid())
  nome              String        // "SDR Qualificação"
  descricao         String?
  templateTipo      IATemplateTipo @default(custom) @map("template_tipo")
  isPublico         Boolean       @default(false) @map("is_publico")

  // Config padrão
  systemPrompt      String        @db.Text
  modelo            AIModel       @default(sonnet)
  temperature       Decimal       @default(0.7) @db.Decimal(2, 1)
  maxTokens         Int           @default(4096) @map("max_tokens")

  // Comportamento
  comportamento     Json          @default("{}") // timeout, retries, logging
  toolsDisponiveis  String[]      @default([]) @map("tools_disponiveis")
  validacoes        Json?

  // Metadata
  versao            Int           @default(1)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relações
  ias               IAInstance[]

  @@index([templateTipo])
  @@map("ia_templates")
}

// Instância de IA (criada pelo usuário)
model IAInstance {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  user            User          @relation("UserIAs", fields: [userId], references: [id], onDelete: Cascade)

  // Info básica
  nome            String
  descricao       String?
  icone           String?       // emoji ou URL

  // Template
  templateId      String?       @map("template_id")
  template        IATemplateModel? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  // Config
  canal           IACanal
  modelo          AIModel       @default(sonnet)
  temperature     Decimal       @default(0.7) @db.Decimal(2, 1)
  maxTokens       Int           @default(4096) @map("max_tokens")

  // Prompt customizável
  systemPrompt    String        @db.Text @map("system_prompt")

  // Comportamento
  comportamento   Json          @default("{}") @map("comportamento")
  toolsAtivas     String[]      @default([]) @map("tools_ativas")

  // Status
  isAtiva         Boolean       @default(true) @map("is_ativa")
  isPublicada     Boolean       @default(false) @map("is_publicada")

  // Credenciais por canal
  canalConfig     Json          @default("{}") @map("canal_config")

  // Metadata
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  lastUsedAt      DateTime?     @map("last_used_at")

  // Stats
  totalConversas  Int           @default(0) @map("total_conversas")
  totalTokensUsado Int          @default(0) @map("total_tokens_usado")
  totalCusto      Decimal       @default(0) @db.Decimal(10, 4) @map("total_custo")

  // Relações
  conversas       IAConversa[]
  logs            IALog[]

  @@index([userId])
  @@index([canal])
  @@index([isAtiva])
  @@map("ia_instances")
}

// Conversa com IA (genérica)
model IAConversa {
  id              String        @id @default(cuid())
  iaId            String        @map("ia_id")
  ia              IAInstance    @relation(fields: [iaId], references: [id], onDelete: Cascade)

  // Participante
  participante    String        // nome do cliente
  participanteId  String?       @map("participante_id") // leadId/clientId
  contactoInfo    Json          @default("{}") @map("contacto_info")

  // Conversa
  mensagens       Json          @default("[]") // [{ role, content, timestamp, tokens }]
  dados           Json          @default("{}") // dados coletados

  // Status
  status          String        @default("ativa") // ativa, concluida, escalonada
  escalonadoEm    DateTime?     @map("escalado_em")

  // Metadata
  canal           IACanal
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([iaId])
  @@index([status])
  @@map("ia_conversas")
}

// Log de IA
model IALog {
  id              String        @id @default(cuid())
  iaId            String        @map("ia_id")
  ia              IAInstance    @relation(fields: [iaId], references: [id], onDelete: Cascade)

  // Log
  nivel           String        // info, warning, error
  mensagem        String
  dados           Json?

  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([iaId])
  @@index([nivel])
  @@map("ia_logs")
}

// Analytics diário de IA
model IAAnaliticsDia {
  id              String        @id @default(cuid())
  iaId            String        @map("ia_id")

  // Data
  data            DateTime

  // Métricas
  conversas       Int           @default(0)
  mensagens       Int           @default(0)
  tokens          Int           @default(0)
  custo           Decimal       @default(0) @db.Decimal(10, 4)
  avgResponseTime Int           @default(0) @map("avg_response_time")
  erros           Int           @default(0)

  @@unique([iaId, data])
  @@map("ia_analytics_dia")
}

// ─── EMAIL IA ─────────────────────────────────────────────────────────────────

enum EmailStatus {
  rascunho
  agendado
  enviando
  enviado
  falha
}

enum EmailInteracaoTipo {
  aberto
  clicado
  descadastrado
  reclamacao
}

// Template de Email
model EmailTemplate {
  id              String        @id @default(cuid())
  nome            String
  descricao       String?
  assunto         String
  corpo           String        // HTML
  variaveis       String[]      @default([]) // lista de variáveis como {{nome}}, {{email}}
  isAtivo         Boolean       @default(true) @map("is_ativo")

  // Metadata
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relações
  campanhas       EmailCampanha[]
  mensagens       EmailMensagem[]

  @@index([isAtivo])
  @@map("email_templates")
}

// Campanha de Email
model EmailCampanha {
  id              String        @id @default(cuid())
  nome            String
  descricao       String?
  templateId      String        @map("template_id")
  template        EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Destinatários
  destinatarios   String[]      // emails
  tagsDestino     String[]      @default([]) // para segmentar

  // Status
  status          EmailStatus   @default(rascunho)
  agendadoEm      DateTime?     @map("agendado_em")
  enviadoEm       DateTime?     @map("enviado_em")

  // Metadata
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Stats
  totalDestina    Int           @default(0) @map("total_destinatarios")
  enviados        Int           @default(0)
  abertos         Int           @default(0)
  clicados        Int           @default(0)
  falhas          Int           @default(0)

  // Relações
  mensagens       EmailMensagem[]

  @@index([status])
  @@index([templateId])
  @@map("email_campanhas")
}

// Mensagem de Email enviada
model EmailMensagem {
  id              String        @id @default(cuid())
  campaignId      String        @map("campaign_id")
  campanha        EmailCampanha @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  templateId      String        @map("template_id")
  template        EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Destinatário
  paraEmail       String        @map("para_email")
  paraNome        String?       @map("para_nome")
  parametros      Json          @default("{}") // valores para variáveis

  // Status
  status          EmailStatus   @default(enviando)
  msgId           String?       @map("msg_id") // ID do provider (SendGrid, etc)
  errorMsg        String?       @map("error_msg")

  // Interações
  abertoEm        DateTime?     @map("aberto_em")
  clicadoEm       DateTime?     @map("clicado_em")
  descadastradoEm DateTime?     @map("descadastrado_em")

  // Metadata
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  enviadoEm       DateTime?     @map("enviado_em")

  // Relações
  interacoes      EmailInteracao[]

  @@index([campaignId])
  @@index([templateId])
  @@index([status])
  @@index([paraEmail])
  @@map("email_mensagens")
}

// Interação com Email
model EmailInteracao {
  id              String            @id @default(cuid())
  mensagemId      String            @map("mensagem_id")
  mensagem        EmailMensagem     @relation(fields: [mensagemId], references: [id], onDelete: Cascade)

  tipo            EmailInteracaoTipo
  ip              String?
  userAgent       String?
  timestamp       DateTime          @default(now())

  @@index([mensagemId])
  @@index([tipo])
  @@map("email_interacoes")
}

// Configuração de Email
model EmailConfig {
  id              String        @id @default(cuid())
  provider        String        // sendgrid, smtp, etc
  apiKey          String?       @db.Text
  fromEmail       String        @map("from_email")
  fromName        String?       @map("from_name")

  // SMTP config (se aplicável)
  smtpHost        String?       @map("smtp_host")
  smtpPort        Int?          @map("smtp_port")
  smtpUser        String?       @map("smtp_user")
  smtpPassword    String?       @db.Text @map("smtp_password")

  // Configurações
  isAtivo         Boolean       @default(true) @map("is_ativo")
  webhookUrl      String?       @map("webhook_url")

  // Metadata
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([provider])
  @@map("email_configs")
}
