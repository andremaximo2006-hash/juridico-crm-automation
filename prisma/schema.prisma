generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  financeiro
  padrao
}

enum OriginChannel {
  instagram
  google
  referral
  direct
  other
}

enum FunnelStage {
  new_lead
  initial_screening
  meeting
  proposal_sent
  contract_signed
  migrated_to_astrea
  lost
}

enum LegalArea {
  familia
  trabalhista
  civil
  criminal
  consumidor
  inventario
  previdenciario
  other
}

enum CaseStatus {
  active
  suspended
  closed_won
  closed_lost
}

enum FeeType {
  pro_labore_entry
  monthly_retainer
  success_fee
}

enum TransactionType {
  income
  expense
}

enum TransactionCategory {
  pro_labore_entry
  monthly_retainer
  success_fee
  office_rent
  software
  marketing
  personnel
  utilities
  other_income
  other_expense
}

enum TransactionStatus {
  pending
  paid
  overdue
  installment
}

enum PaymentMethod {
  pix
  bank_transfer
  credit_card
  cash
  other
}

enum NotificationType {
  payment_due
  payment_overdue
  collection_reminder
  stage_reminder
  custom
}

enum WhatsAppPlatform {
  zapi
  meta
  manychat
}

enum WhatsAppConversationStatus {
  active
  transferred
  completed
  closed
}

enum WhatsAppHumanTicketStatus {
  pending
  assigned
  in_progress
  resolved
  cancelled
}

enum WhatsAppHumanTicketPriority {
  low
  normal
  high
}

enum NotificationChannel {
  whatsapp
  email
  internal
}

enum NotificationStatus {
  pending
  sent
  failed
  cancelled
}

enum TimelineEventType {
  call
  whatsapp
  email
  meeting
  note
  stage_change
  proposal_sent
}

enum MarketingChannel {
  instagram
  google
  facebook
  other
